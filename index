  const th = HEADERS.map(h=>`<th>${esc(h)}</th>`).join("");
  const trs = LAST.items.map(it=>`<tr>
    <td style="text-align:right">${it.no}</td>
    <td>${esc(it.dimensi)}</td>
    <td>${esc(it.indikator)}</td>
    <td>${esc(it.tingkatLabel)}</td>
    <td>${esc(it.pernyataan)}</td>
    <td>${esc(it.arah)}</td>
    <td>${esc(it.catatan)}</td>
  </tr>`).join("");

  const html =
`<!DOCTYPE html><html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:w="urn:schemas-microsoft-com:office:word" xmlns="http://www.w3.org/TR/REC-html40">
<head><meta charset="utf-8"><title>Angket Minat ${esc(m.mapel)}</title>
<style>
  body{font-family:Calibri,Arial,sans-serif;color:#1f2a44;font-size:11pt}
  h1{font-size:16pt;margin:0 0 4pt}
  .sub{color:#555;font-size:10pt;margin:0 0 12pt}
  table{border-collapse:collapse;width:100%;font-size:9.5pt}
  th,td{border:1px solid #99a;padding:5pt 6pt;vertical-align:top;text-align:left}
  th{background:#2f5d8a;color:#fff}
  .narasi{margin-top:14pt;border-left:3px solid #2f5d8a;padding:8pt 10pt;background:#eef1f5;font-size:10pt}
</style></head>
<body>
  <h1>Angket Minat Belajar Siswa</h1>
  <p class="sub">
    Mata pelajaran: <b>${esc(m.mapel)}</b> &nbsp;|&nbsp; Kelas: <b>${esc(m.kelas)}</b> &nbsp;|&nbsp; Materi: <b>${esc(m.objek||"-")}</b><br>
    Jumlah butir: ${m.jumlah} &nbsp;|&nbsp; Skala: ${esc(m.skala)} &nbsp;|&nbsp; Tanggal: ${esc(m.tanggal)}
  </p>
  <table><thead><tr>${th}</tr></thead><tbody>${trs}</tbody></table>
  <div class="narasi">
    <p>${esc(NARASI)}</p>
    <p style="color:#555">Tingkat mudah/sedang/tinggi menunjukkan kemungkinan siswa menyetujui pernyataan, bukan tingkat kesulitan soal. Validitas, reliabilitas, separasi, dan kecocokan butir sebaiknya diuji dengan data responden (mis. analisis Rasch/RASA).</p>
  </div>
</body></html>`;

  download(fileBase(LAST)+".doc", html, "application/msword");
  toast("Dokumen Word/HTML terunduh");
}

/* ---------- Reset ---------- */
function reset(){
  $("mapel").value="Matematika";
  $("objek").value="";
  $("kelas").value="IV SD";
  $("jumlah").value="24";
  $("mapelLain").value="";
  $("mapelLain").classList.remove("show");
  $("output").classList.remove("show");
  $("angketBody").innerHTML=""; $("metaBox").innerHTML="";
  ["btnCopy","btnCsv","btnDoc"].forEach(id=>$(id).disabled=true);
  clearError();
  LAST=null;
  window.scrollTo({top:0,behavior:"smooth"});
}

