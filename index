let LAST = null; // menyimpan hasil generate terakhir untuk ekspor

/* ---------- Util ---------- */
const $ = (id) => document.getElementById(id);

function toggleExtra(selId, extraId){
  const sel = $(selId), extra = $(extraId);
  const on = sel.value === "__lain__";
  extra.classList.toggle("show", on);
  if(on) extra.focus();
}

function getMapel(){
  const sel = $("mapel").value;
  if(sel === "__lain__") return $("mapelLain").value.trim();
  return sel;
}
function getObjek(){
  return $("objek").value.trim();
}
function fill(tmpl, v){
  return tmpl
    .replace(/\[MATA_PELAJARAN\]/g, v.mapel)
    .replace(/\[MATERI\]/g, v.materi)
    .replace(/\[GURU\]/g, v.guru)
    .replace(/\[TEMAN\]/g, v.teman);
}
function shuffle(arr){
  const a = arr.slice();
  for(let i=a.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); [a[i],a[j]]=[a[j],a[i]]; }
  return a;
}
function countWords(s){
  return s.replace(/[.,]/g," ").trim().split(/\s+/).filter(Boolean).length;
}
function qualityNote(text, lvl){
  const base = {
    mudah:  "Pernyataan umum; banyak siswa cenderung setuju. Jangan terlalu banyak butir mudah agar separasi tidak menurun.",
    sedang: "Mengukur minat yang lebih nyata; sebaran jawaban diharapkan bervariasi.",
    tinggi: "Menuntut minat kuat; persentase setuju cenderung lebih rendah dan menjangkau ujung atas skala."
  }[lvl];
  const panjang = countWords(text) > 12
    ? "Kalimat agak panjang — pertimbangkan untuk diringkas."
    : "Panjang kalimat sesuai untuk siswa SD.";
  return base + " " + panjang + " Tetap perlu diuji empiris (validitas, item fit).";
}

function showError(msg){ const e=$("errBox"); e.textContent=msg; e.classList.add("err"); }
function clearError(){ const e=$("errBox"); e.textContent=""; e.classList.remove("err"); }

let toastTimer=null;
function toast(msg){
  const t=$("toast"); t.textContent=msg; t.classList.add("show");
  clearTimeout(toastTimer); toastTimer=setTimeout(()=>t.classList.remove("show"),1900);
}

/* ---------- Generate ---------- */
function generate(){
  clearError();
  const mapel = getMapel();
  const kelas = $("kelas").value.trim();
  const objek = getObjek();
  const jumlah = parseInt($("jumlah").value,10);

  if(!mapel){ showError("Mohon isi nama mata pelajaran terlebih dahulu."); return; }
  if(!kelas){ showError("Mohon isi kelas siswa terlebih dahulu."); return; }

  const konteksVals = {
    mapel: mapel,
    materi: objek || mapel,   // jika materi kosong, rujuk ke mata pelajaran
    guru: "guru",
    teman: "teman"
  };

  // Round-robin level-major untuk menghitung kuota tiap kombinasi (distribusi seimbang antar dimensi)
  const combos = [];
  for(const lvl of LEVELS){
    for(let d=0; d<DIMENSI.length; d++) combos.push({ d, lvl, n:0 });
  }
  for(let i=0;i<jumlah;i++) combos[i % combos.length].n++;

  // Pilih template acak (tanpa pengulangan) sebanyak kuota dari tiap kombinasi
  const raw = [];
  for(const c of combos){
    if(c.n === 0) continue;
    const pool = DIMENSI[c.d].butir[c.lvl];
    const picked = shuffle(pool).slice(0, Math.min(c.n, pool.length));
    picked.forEach(tmpl => raw.push({ d:c.d, lvl:c.lvl, tmpl }));
  }

  // Urutkan tampilan: per dimensi, lalu per tingkat
  raw.sort((a,b)=> (a.d-b.d) || (LEVEL_ORDER[a.lvl]-LEVEL_ORDER[b.lvl]));

  const items = raw.map((r,idx)=>{
    const dim = DIMENSI[r.d];
    const text = fill(r.tmpl, konteksVals);
    return {
      no: idx+1,
      dimensi: dim.nama,
      indikator: dim.indikator[r.lvl],
      tingkat: r.lvl,
      tingkatLabel: LEVEL_LABEL[r.lvl],
      pernyataan: text,
      arah: "Favorable (+)",
      catatan: qualityNote(text, r.lvl)
    };
  });

  LAST = {
    meta: { mapel, kelas, objek, jumlah, skala: SKALA_TEKS, tanggal: new Date().toLocaleDateString("id-ID",{day:"2-digit",month:"long",year:"numeric"}) },
    items
  };

  render(LAST);
}

function render(data){
  // Meta
  const m = data.meta;
  $("metaBox").innerHTML = [
    ["Mata pelajaran", m.mapel],
    ["Kelas", m.kelas],
    ["Materi pembelajaran", m.objek || "—"],
    ["Jumlah butir", m.jumlah + " butir"],
    ["Skala", "4 tingkat (Likert)"],
    ["Tanggal", m.tanggal]
  ].map(([k,v])=>`<div><div class="k">${esc(k)}</div><div class="v">${esc(v)}</div></div>`).join("");

  // Tabel
  $("angketBody").innerHTML = data.items.map(it=>`
    <tr>
      <td class="no">${it.no}</td>
      <td class="dim">${esc(it.dimensi)}</td>
      <td>${esc(it.indikator)}</td>
      <td><span class="pill ${it.tingkat}">${esc(it.tingkatLabel)}</span></td>
      <td class="statement">${esc(it.pernyataan)}</td>
      <td class="arah">${esc(it.arah)}</td>
      <td class="note">${esc(it.catatan)}</td>
    </tr>`).join("");

  $("output").classList.add("show");
  ["btnCopy","btnCsv","btnDoc"].forEach(id=>$(id).disabled=false);
  $("output").scrollIntoView({behavior:"smooth",block:"start"});
}

function esc(s){
  return String(s==null?"":s)
    .replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;")
    .replace(/"/g,"&quot;").replace(/'/g,"&#39;");
}

/* ---------- Ekspor ---------- */
const HEADERS = ["No","Dimensi","Indikator","Tingkat Butir","Pernyataan Angket","Arah Butir","Catatan Kualitas Butir"];

function rowsOf(data){
  return data.items.map(it=>[it.no,it.dimensi,it.indikator,it.tingkatLabel,it.pernyataan,it.arah,it.catatan]);
}
function fileBase(data){
  const mp = (data.meta.mapel||"angket").replace(/[^\w\u00C0-\u024F ]/g,"").trim().replace(/\s+/g,"_");
  return `Angket_Minat_${mp}_${data.meta.jumlah}butir`;
}
function download(filename, content, mime){
  const blob = new Blob([content], {type:mime});
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url; a.download = filename; document.body.appendChild(a); a.click();
  a.remove(); setTimeout(()=>URL.revokeObjectURL(url),500);
}

const NARASI = "Angket ini merupakan draft awal. Kualitas instrumen tetap perlu diuji melalui uji coba kepada siswa. Reliabilitas, separation, item fit, dan fungsi kategori jawaban perlu dianalisis sebelum angket digunakan sebagai instrumen final.";

/* TSV ke clipboard (mudah ditempel ke Excel/Word) */
function copyClipboard(){
  if(!LAST) return;
  const m = LAST.meta;
  const safe = (s)=>String(s).replace(/[\t\r\n]+/g," ").trim();
  const lines = [];
  lines.push(`Angket Minat Belajar Siswa`);
  lines.push(`Mata pelajaran: ${m.mapel}\tKelas: ${m.kelas}\tMateri: ${m.objek || "-"}`);
  lines.push(`Skala: ${m.skala}`);
  lines.push("");
  lines.push(HEADERS.join("\t"));
  rowsOf(LAST).forEach(r=>lines.push(r.map(safe).join("\t")));
  lines.push("");
  lines.push(NARASI);
  const text = lines.join("\n");

  const done = ()=>toast("Tersalin ke clipboard");
  if(navigator.clipboard && navigator.clipboard.writeText){
    navigator.clipboard.writeText(text).then(done).catch(()=>fallbackCopy(text,done));
  } else {
    fallbackCopy(text, done);
  }
}
function fallbackCopy(text, cb){
  const ta=document.createElement("textarea");
  ta.value=text; ta.style.position="fixed"; ta.style.opacity="0";
  document.body.appendChild(ta); ta.select();
  try{ document.execCommand("copy"); cb(); }catch(e){ toast("Tidak dapat menyalin otomatis"); }
  ta.remove();
}

/* CSV (UTF-8 + BOM agar rapi di Excel) */
function csvCell(s){
  s = String(s==null?"":s);
  return /[",\n]/.test(s) ? '"'+s.replace(/"/g,'""')+'"' : s;
}
function downloadCsv(){
  if(!LAST) return;
  const m = LAST.meta;
  const rows = [];
  rows.push(["Angket Minat Belajar Siswa"]);
  rows.push(["Mata pelajaran", m.mapel]);
  rows.push(["Kelas", m.kelas]);
  rows.push(["Materi pembelajaran", m.objek || "-"]);
  rows.push(["Jumlah butir", m.jumlah]);
  rows.push(["Skala", m.skala]);
  rows.push(["Tanggal", m.tanggal]);
  rows.push([]);
  rows.push(HEADERS);
  rowsOf(LAST).forEach(r=>rows.push(r));
  rows.push([]);
  rows.push(["Catatan", NARASI]);
  const csv = "\ufeff" + rows.map(r=>r.map(csvCell).join(",")).join("\r\n");
  download(fileBase(LAST)+".csv", csv, "text/csv;charset=utf-8");
  toast("CSV terunduh");
}

/* Word/HTML sederhana (.doc, dapat dibuka di MS Word & browser) */
